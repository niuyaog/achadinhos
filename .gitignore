# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# next.js
.next/
out/

# production
build/
dist/

# env files (strict block to prevent credential leakage)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*

# vercel
.vercel/

# logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS / IDE
.DS_Store
Thumbs.db
desktop.ini
*Zone.Identifier
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# coverage/cache
coverage/
.cache/
.turbo/
*.tsbuildinfo
next-env.d.ts

# local temp/backups
*.bak
*.backup
*.tmp
temp/
tmp/

# local docs / references not for repo
*.docx

# loose generated/reference images
b7ad364c-7dd8-4671-87cf-a3eabecca41b*.png

# audit / internal documentation markdown (keep README, AGENTS, CLAUDE)
/*.md
